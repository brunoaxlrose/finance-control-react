{
  "expo": {
    "name": "Finance BR",
    "slug": "project-finance",
    "scheme": "projectfinance",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2C2924"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.brunoaxlrose.projectfinance",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Permitir o uso do Face ID para entrar no aplicativo com segurança."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2C2924"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.brunoaxlrose.projectfinance"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "5ae00665-4328-4a2e-b768-87670b6a54a4"
      }
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      "expo-secure-store"
    ]
  }
}
